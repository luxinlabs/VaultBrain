DATABASE_URL=postgresql://user:password@localhost:5432/dealflow_ai
JWT_SECRET=your-secret-key-change-in-production

# The Hog API credentials (get from https://platform.thehog.ai)
HOG_ACCESS_KEY=ak_your_access_key_here
HOG_SECRET_KEY=sk_your_secret_key_here
# Optional: override base URL if using a different Hog environment
# HOG_API_BASE_URL=https://developer.thehog.ai

PORT=3001
NODE_ENV=development

# Seed script credentials (required for first run)
SEED_PARTNER_EMAIL=you@example.com
SEED_PARTNER_PASSWORD=change-me
# Optional analyst account
# SEED_ANALYST_EMAIL=analyst@example.com
# SEED_ANALYST_PASSWORD=change-me-too
